// ==UserScript==
// @name         Facebook Auto Expand Everything
// @namespace    cody.facebook.expand
// @version      1.0
// @description  Automatically expands Facebook comments, replies, and "see more" text.
// @match        https://www.facebook.com/*
// @match        https://m.facebook.com/*
// @match        https://mbasic.facebook.com/*
// @grant        none
// ==/UserScript==

(function () {
  'use strict';

  const CLICK_DELAY = 900;
  const SCAN_INTERVAL = 1500;

  const phrases = [
    'see more',
    'view more comments',
    'view previous comments',
    'view more replies',
    'view replies',
    'more comments',
    'more replies',
    'show more',
    'load more'
  ];

  function sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  function isVisible(el) {
    if (!el) return false;
    const rect = el.getBoundingClientRect();
    return rect.width > 0 && rect.height > 0;
  }

  function looksExpandable(el) {
    const text = (el.innerText || el.textContent || '').trim().toLowerCase();

    if (!text) return false;

    return phrases.some(phrase => text.includes(phrase));
  }

  async function expandPage() {
    const candidates = Array.from(
      document.querySelectorAll('div[role="button"], span, a, button')
    ).filter(el => isVisible(el) && looksExpandable(el));

    for (const el of candidates) {
      try {
        el.scrollIntoView({
          behavior: 'smooth',
          block: 'center'
        });

        await sleep(250);
        el.click();

        console.log('[FB Auto Expand] Clicked:', el.innerText || el.textContent);
        await sleep(CLICK_DELAY);
      } catch (err) {
        console.warn('[FB Auto Expand] Failed to click:', err);
      }
    }
  }

  async function autoScroll() {
    window.scrollBy({
      top: window.innerHeight * 0.85,
      behavior: 'smooth'
    });
  }

  async function loop() {
    await expandPage();
    await autoScroll();
  }

  setInterval(loop, SCAN_INTERVAL);

  console.log('[FB Auto Expand] Running.');
})();
