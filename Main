// ==UserScript==
// @name         Facebook Auto Expand Everything
// @namespace    cody.facebook.expand
// @version      2.1
// @description  Adds an on-screen/Tampermonkey toggle to expand Facebook comments, replies, reaction/like lists, and "see more" text on demand.
// @match        https://www.facebook.com/*
// @match        https://m.facebook.com/*
// @match        https://mbasic.facebook.com/*
// @grant        GM_registerMenuCommand
// @run-at       document-start
// ==/UserScript==

(function () {
  'use strict';

  const CONFIG = {
    scanInterval: 450,
    idleScanInterval: 1500,
    maxClicksPerPass: 50,
    maxScrollsPerPass: 2,
    clickCooldown: 900,
    scrollAmount: 0.9,
    bootBurstMs: 8000,
    debug: false
  };

  const EXPAND_PHRASES = [
    'see more',
    'show more',
    'read more',
    'continue reading',
    'view more comments',
    'view previous comments',
    'view more replies',
    'view previous replies',
    'view replies',
    'view reply',
    'more comments',
    'previous comments',
    'more replies',
    'load more comments',
    'load more replies',
    'load more',
    'all comments',
    'most relevant',
    'show all',
    'see all',
    'all reactions',
    'others',
    'and others',
    'people reacted',
    'replies',
    'comments'
  ];

  const EXACT_SKIP_TEXT = new Set([
    'like',
    'liked',
    'comment',
    'share',
    'send',
    'follow',
    'unfollow',
    'join',
    'joined',
    'message',
    'save',
    'saved'
  ]);

  const CLICKABLE_SELECTOR = [
    'a[href]',
    'button',
    '[role="button"]',
    '[role="link"]',
    '[tabindex="0"]',
    'summary'
  ].join(',');

  const clicked = new WeakMap();
  let queued = false;
  let enabled = false;
  let toggleButton = null;
  let observer = null;
  let scanTimer = null;
  let idleTimer = null;
  let lastActivity = Date.now();

  function log(...args) {
    if (CONFIG.debug) console.log('[FB Auto Expand]', ...args);
  }

  function normalizeText(text) {
    return (text || '')
      .replace(/\s+/g, ' ')
      .replace(/[·•]/g, ' ')
      .trim()
      .toLowerCase();
  }

  function visible(el) {
    if (!el || !el.isConnected) return false;
    const style = getComputedStyle(el);
    if (style.visibility === 'hidden' || style.display === 'none' || style.pointerEvents === 'none') return false;
    const rect = el.getBoundingClientRect();
    return rect.width > 0 && rect.height > 0 && rect.bottom >= -200 && rect.top <= window.innerHeight + 1200;
  }

  function recentlyClicked(el) {
    return Date.now() - (clicked.get(el) || 0) < CONFIG.clickCooldown;
  }

  function hasExpandableCount(text) {
    return /(?:^|\s)\d+[,.]?\d*\s*(?:k|m)?\s*(?:comments?|replies|shares?|others?|reactions?|likes?)\b/i.test(text)
      || /\b\d+\s+of\s+\d+\b/i.test(text);
  }

  function hrefLooksExpandable(el) {
    const href = (el.getAttribute('href') || '').toLowerCase();
    return href.includes('comment')
      || href.includes('reaction')
      || href.includes('ufi/reaction')
      || href.includes('likes')
      || href.includes('feedback');
  }

  function isUnsafeAction(el, text) {
    const aria = normalizeText(el.getAttribute('aria-label'));
    const combined = normalizeText(`${aria} ${text}`);

    if (EXACT_SKIP_TEXT.has(text) || EXACT_SKIP_TEXT.has(aria)) return true;
    if (/^(like|comment|share|send|follow|join|message|save)\b/.test(combined)) return true;
    if (/\b(unfriend|block|report|delete|hide|remove|turn on notifications|turn off notifications)\b/.test(combined)) return true;

    return false;
  }

  function looksExpandable(el) {
    const text = normalizeText(`${el.getAttribute('aria-label') || ''} ${el.innerText || el.textContent || ''}`);
    if (!text || text.length > 240 || isUnsafeAction(el, text)) return false;

    return EXPAND_PHRASES.some(phrase => text.includes(phrase))
      || hasExpandableCount(text)
      || hrefLooksExpandable(el);
  }

  function getCandidates(root = document) {
    const nodes = Array.from(root.querySelectorAll ? root.querySelectorAll(CLICKABLE_SELECTOR) : []);
    if (root.matches && root.matches(CLICKABLE_SELECTOR)) nodes.unshift(root);

    return nodes
      .filter(el => visible(el) && !recentlyClicked(el) && looksExpandable(el))
      .sort((a, b) => a.getBoundingClientRect().top - b.getBoundingClientRect().top);
  }

  function fastClick(el) {
    clicked.set(el, Date.now());
    el.scrollIntoView({ block: 'center', inline: 'nearest', behavior: 'auto' });
    el.dispatchEvent(new MouseEvent('mouseover', { bubbles: true, cancelable: true, view: window }));
    el.dispatchEvent(new MouseEvent('mousedown', { bubbles: true, cancelable: true, view: window }));
    el.dispatchEvent(new MouseEvent('mouseup', { bubbles: true, cancelable: true, view: window }));
    el.click();
    lastActivity = Date.now();
    log('clicked', normalizeText(el.innerText || el.textContent || el.getAttribute('aria-label')));
  }

  function expand(root = document) {
    let count = 0;
    for (const el of getCandidates(root)) {
      if (count >= CONFIG.maxClicksPerPass) break;
      try {
        fastClick(el);
        count += 1;
      } catch (err) {
        log('click failed', err);
      }
    }
    return count;
  }

  function autoScroll() {
    let scrolls = 0;
    while (scrolls < CONFIG.maxScrollsPerPass && document.documentElement.scrollHeight - window.scrollY - window.innerHeight > 2) {
      window.scrollBy({ top: window.innerHeight * CONFIG.scrollAmount, behavior: 'auto' });
      scrolls += 1;
    }
  }

  function runPass(root = document) {
    const expanded = expand(root);
    if (Date.now() - lastActivity < CONFIG.bootBurstMs || expanded > 0) autoScroll();
  }

  function schedule(root = document, force = false) {
    if (!enabled && !force) return;
    if (queued) return;
    queued = true;
    requestAnimationFrame(() => {
      queued = false;
      if (enabled || force) runPass(root);
    });
  }

  function setButtonState() {
    if (!toggleButton) return;
    toggleButton.textContent = enabled ? 'FB Expand: ON' : 'FB Expand: OFF';
    toggleButton.title = enabled
      ? 'Facebook Auto Expand is running. Click to stop.'
      : 'Click to expand comments, replies, likes/reactions, and see-more text.';
    toggleButton.style.background = enabled ? '#1877f2' : '#3a3b3c';
  }

  function createToggleButton() {
    if (toggleButton || !document.body) return;

    toggleButton = document.createElement('button');
    toggleButton.type = 'button';
    toggleButton.setAttribute('aria-pressed', String(enabled));
    toggleButton.style.cssText = [
      'position:fixed',
      'right:16px',
      'bottom:16px',
      'z-index:2147483647',
      'border:0',
      'border-radius:999px',
      'padding:10px 14px',
      'color:#fff',
      'font:600 13px/1.2 system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif',
      'box-shadow:0 4px 14px rgba(0,0,0,.35)',
      'cursor:pointer'
    ].join(';');
    toggleButton.addEventListener('click', () => setEnabled(!enabled));
    document.body.appendChild(toggleButton);
    setButtonState();
  }

  function registerMenu() {
    if (typeof GM_registerMenuCommand !== 'function') return;
    GM_registerMenuCommand('Toggle Facebook Auto Expand', () => setEnabled(!enabled));
    GM_registerMenuCommand('Expand Facebook Page Once', () => schedule(document, true));
  }

  function startAutomation() {
    stopAutomation();
    lastActivity = Date.now();
    schedule();

    scanTimer = setInterval(() => schedule(), CONFIG.scanInterval);
    idleTimer = setInterval(() => {
      if (Date.now() - lastActivity > CONFIG.bootBurstMs) schedule();
    }, CONFIG.idleScanInterval);

    observer = new MutationObserver(mutations => {
      for (const mutation of mutations) {
        for (const node of mutation.addedNodes) {
          if (node.nodeType === Node.ELEMENT_NODE) schedule(node);
        }
      }
    });
    observer.observe(document.documentElement, { childList: true, subtree: true });
  }

  function stopAutomation() {
    if (scanTimer) clearInterval(scanTimer);
    if (idleTimer) clearInterval(idleTimer);
    if (observer) observer.disconnect();
    scanTimer = null;
    idleTimer = null;
    observer = null;
    queued = false;
  }

  function setEnabled(nextEnabled) {
    enabled = nextEnabled;
    if (toggleButton) toggleButton.setAttribute('aria-pressed', String(enabled));
    setButtonState();

    if (enabled) {
      startAutomation();
      console.log('[FB Auto Expand] Enabled.');
    } else {
      stopAutomation();
      console.log('[FB Auto Expand] Disabled.');
    }
  }

  function start() {
    createToggleButton();
    registerMenu();
    console.log('[FB Auto Expand] Ready. Use the on-screen button or Tampermonkey menu to start expanding.');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start, { once: true });
  } else {
    start();
  }
})();
